# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# Email Configuration (for notifications)
VITE_EMAIL_SERVICE_URL=https://api.sendgrid.com/v3/mail/send
VITE_EMAIL_API_KEY=your_sendgrid_api_key_here

# LINE Configuration (for LINE notifications)
VITE_LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
VITE_LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Database Configuration (for backend)
DATABASE_URL=postgresql://username:password@localhost:5432/quiet_estate_forge
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=quiet_estate_forge
DATABASE_USER=username
DATABASE_PASSWORD=password

# JWT Configuration (for backend)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# File Upload Configuration
VITE_UPLOAD_URL=http://localhost:3001/api/upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Google Maps API (for property location)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Development/Production flags
NODE_ENV=development
VITE_APP_ENV=development
